{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

set -eufo pipefail

{{ $brews := list
       "bat"
       "buildpacks/tap/pack"
       "curl"
       "direnv"
       "exa"
       "ffmpeg"
       "fish"
       "fzf"
       "gh"
       "git-delta"
       "git-lfs"
       "git"
       "gnu-units"
       "go"
       "hostess"
       "hugo"
       "imagemagick" 
       "libjpeg"
       "micro"
       "node"
       "protobuf"
       "starship"
       "tmux"
       "wget"
       "zlib"
       "zoxide" -}}
{{ $casks := list
       "1password"
       "1password-cli"
       "alfred"
       "bettertouchtool"
       "dash"
       "docker"
       "firefox"
       "font-fira-code"
       "iterm2"
       "kaleidoscope"
       "rectangle"
       "spotify"
       "sublime-text"
       "visual-studio-code" -}}


{{ if .personal -}}
{{ $casks = concat $casks (list
       "google-chrome"
       "google-cloud-sdk") -}}
{{ end -}}

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF

{{ end -}}