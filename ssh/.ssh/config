# Load local/work-specific configurations that are NOT committed to this repo.
# config.local = single-file personal overrides (gitignored here).
# config.d/*   = drop-in directory for a separate private/work dotfiles repo.
#                Missing-glob matches are silently ignored by ssh_config.
Include config.local
Include config.d/*

# Per-host blocks come BEFORE `Host *` because ssh_config is first-match-wins
# per option. Trusted hosts opt in to ForwardAgent here; everything else
# inherits the safe `ForwardAgent no` default from the wildcard block below.

Host github.com
    User git
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    ForwardAgent yes

Host yoyo-prod
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
    ForwardAgent yes

# Default settings for all hosts for maximum connection experience, less touches
Host *
    # Connection multiplexing (ControlMaster)
    # Allows multiple ssh sessions to share a single TCP connection,
    # so subsequent logins are instant
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h:%p
    ControlPersist 10m

    # Keep connections alive (ServerAlive)
    # Prevents firewalls from timing out inactive connections
    ServerAliveInterval 60
    ServerAliveCountMax 5

    # Agent forwarding is OFF by default — scoped per-host above.
    # A compromised remote root can hijack the 1Password agent socket
    # when forwarding is enabled, so only trusted hosts get it.
    ForwardAgent no

    # Compression for better experience on slower connections
    Compression yes

    # Extra features
    VisualHostKey yes
