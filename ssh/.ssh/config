# Load local/work-specific configurations that are NOT committed to dotfiles
Include config.local

# Default settings for all hosts for maximum connection experience, less touches
Host *
    # Connection multiplexing (ControlMaster)
    # Allows multiple ssh sessions to share a single TCP connection,
    # so subsequent logins are instant
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h:%p
    ControlPersist 10m

    # Keep connections alive (ServerAlive)
    # Prevents firewalls from timing out inactive connections
    ServerAliveInterval 60
    ServerAliveCountMax 5

    # Agent forwarding (ForwardAgent)
    # Simplifies multi-hop authentication; handle with care
    ForwardAgent yes

    # Compression for better experience on slower connections
    Compression yes

    # Extra features
    VisualHostKey yes
