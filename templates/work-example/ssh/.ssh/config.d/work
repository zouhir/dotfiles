# Work SSH hosts — loaded via `Include config.d/*` in the public ~/.ssh/config.
# ssh_config is first-match-wins, and this file is included AFTER the main
# config's specific host blocks but BEFORE its `Host *` default block, so
# per-host settings here will take effect. Put only work hosts here.

# Host corp-bastion
#     HostName bastion.corp.example
#     User zchahoud
#     IdentitiesOnly yes
#     IdentityFile ~/.ssh/id_ed25519_work.pub
#     ForwardAgent yes

# Host corp-*.internal
#     ProxyJump corp-bastion
#     User zchahoud
#     ForwardAgent yes
